# Base URL of your Supabase public storage bucket for 3D scans.
# Find your project ref in the Supabase dashboard URL, then use a public bucket
# named e.g. "scans":
#
#   NEXT_PUBLIC_SCAN_BASE_URL=https://<project-ref>.supabase.co/storage/v1/object/public/scans
#
# Properties whose `splat` is a bare filename (e.g. "model.ksplat") are loaded from
# this base. Properties with a full URL or a /public path ignore it.
NEXT_PUBLIC_SCAN_BASE_URL=

# Optional: Anthropic API key to power the Q&A chatbot with an LLM (server-side only).
# Get one at https://console.anthropic.com/ . If unset, the chat falls back to the
# free rule-based answerer automatically — no key required to run.
ANTHROPIC_API_KEY=
