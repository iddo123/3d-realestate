# Scan binaries: ignore everything in public/scans EXCEPT the deployed lite scan,
# which is served fast from Vercel's CDN (same-origin, no external round-trip).
public/scans/*
!public/scans/Model-lite.ksplat

# Dev-only files that don't belong in the deployment
scripts/
e2e/
tests/
docs/
test-results/
playwright-report/
playwright.config.js
vitest.config.js
